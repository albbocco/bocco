{
  "name": "WF-02: Création Avatar Payant",
  "nodes": [
    {
      "id": "webhook-start",
      "name": "Webhook - Create Avatar",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "create-paid-avatar",
      "parameters": {
        "httpMethod": "POST",
        "path": "create-paid-avatar",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "verify-credits",
      "name": "Check Credits",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [450, 300],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase PostgreSQL"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT credits_remaining FROM users WHERE id = '{{ $json.body.user_id }}';"
      }
    },
    {
      "id": "credits-sufficient",
      "name": "Credits >= 1?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [650, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json[0].credits_remaining }}",
              "rightValue": "1",
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ]
        }
      }
    },
    {
      "id": "error-insufficient",
      "name": "Error - Insufficient Credits",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [650, 500],
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\"success\": false, \"error\": \"INSUFFICIENT_CREDITS\", \"message\": \"Crédits insuffisants. Achetez des crédits pour continuer.\"}",
        "options": {
          "responseCode": 402
        }
      }
    },
    {
      "id": "generate-prompt",
      "name": "Generate Optimized Prompt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "gpt-4o-mini"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Tu es un expert en génération d'images. Optimise la description utilisateur pour créer un prompt professionnel pour un avatar.\"}, {\"role\": \"user\", \"content\": \"Description: {{ $json.body.description }}. Style: {{ $json.body.style || 'professionnel' }}\"}]"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "fal-generate",
      "name": "FAL.ai - Generate Avatar Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 300],
      "parameters": {
        "method": "POST",
        "url": "https://queue.fal.run/fal-ai/flux-pro/v1.1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "prompt",
              "value": "={{ $json.choices[0].message.content }}"
            },
            {
              "name": "image_size",
              "value": "square_hd"
            },
            {
              "name": "num_images",
              "value": "1"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "poll-fal",
      "name": "Poll FAL Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 300],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.response_url }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 60000
        }
      },
      "retryOnFail": true,
      "waitBetweenTries": 5000,
      "maxTries": 20
    },
    {
      "id": "generate-script",
      "name": "Generate Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1450, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "gpt-4o-mini"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Génère une phrase de présentation courte (5-10 mots) pour un avatar.\"}, {\"role\": \"user\", \"content\": \"Description avatar: {{ $json.body.description }}\"}]"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "hailuo-animate",
      "name": "Hailuo/PiAPI - Animate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.piapi.ai/api/v1/task",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "luma"
            },
            {
              "name": "task_type",
              "value": "video_generation"
            },
            {
              "name": "input",
              "value": "={\"image_url\": \"{{ $json.images[0].url }}", \"prompt\": \"{{ $json.choices[0].message.content }}\"}"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      }
    },
    {
      "id": "poll-hailuo",
      "name": "Poll Hailuo Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1850, 300],
      "parameters": {
        "method": "GET",
        "url": "=https://api.piapi.ai/api/v1/task/{{ $json.data.task_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 60000
        }
      },
      "retryOnFail": true,
      "waitBetweenTries": 10000,
      "maxTries": 30
    },
    {
      "id": "deduct-credits",
      "name": "Deduct 1 Credit",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [2050, 300],
      "parameters": {
        "workflowId": {
          "__rl": true,
          "mode": "list",
          "value": "WF-05: Gestion Crédits"
        },
        "workflowInputs": {
          "values": [
            {
              "name": "user_id",
              "value": "={{ $json.body.user_id }}"
            },
            {
              "name": "amount",
              "value": "-1"
            },
            {
              "name": "description",
              "value": "Création avatar payant"
            },
            {
              "name": "type",
              "value": "usage"
            }
          ]
        }
      }
    },
    {
      "id": "save-avatar",
      "name": "Save Avatar to DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2250, 300],
      "credentials": {
        "postgres": {
          "id": "supabase-db",
          "name": "Supabase PostgreSQL"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO avatars (user_id, image_url, video_url, prompt_used, is_free, created_at, status) VALUES ('{{ $json.body.user_id }}', '{{ $json.images[0].url }}', '{{ $json.data.output.video_url }}', '{{ $json.body.description }}', false, NOW(), 'active');"
      }
    },
    {
      "id": "send-confirmation",
      "name": "Send Confirmation Email",
      "type": "n8n-nodes-base.sendEmail",
      "typeVersion": 2.1,
      "position": [2450, 300],
      "credentials": {
        "smtp": {
          "id": "brevo-smtp",
          "name": "Brevo SMTP"
        }
      },
      "parameters": {
        "toAddresses": "={{ $json.body.email }}",
        "subject": "Votre avatar est prêt !",
        "text": "Votre avatar payant a été créé avec succès. Lien : {{ $json.data.output.video_url }}",
        "html": "<h1>Votre avatar est prêt !</h1><p><a href='{{ $json.data.output.video_url }}'>Voir mon avatar</a></p>"
      }
    },
    {
      "id": "response-success",
      "name": "Response - Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2650, 300],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"success\": true, \"message\": \"Avatar créé avec succès. 1 crédit déduit.\"}"
      }
    }
  ],
  "connections": {
    "Webhook - Create Avatar": {
      "main": [
        [
          {
            "node": "Check Credits",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Credits": {
      "main": [
        [
          {
            "node": "Credits >= 1?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Credits >= 1?": {
      "main": [
        [
          {
            "node": "Generate Optimized Prompt",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Error - Insufficient Credits",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Optimized Prompt": {
      "main": [
        [
          {
            "node": "FAL.ai - Generate Avatar Image",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "FAL.ai - Generate Avatar Image": {
      "main": [
        [
          {
            "node": "Poll FAL Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Poll FAL Status": {
      "main": [
        [
          {
            "node": "Generate Script",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Script": {
      "main": [
        [
          {
            "node": "Hailuo/PiAPI - Animate",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Hailuo/PiAPI - Animate": {
      "main": [
        [
          {
            "node": "Poll Hailuo Status",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Poll Hailuo Status": {
      "main": [
        [
          {
            "node": "Deduct 1 Credit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Deduct 1 Credit": {
      "main": [
        [
          {
            "node": "Save Avatar to DB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Save Avatar to DB": {
      "main": [
        [
          {
            "node": "Send Confirmation Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Confirmation Email": {
      "main": [
        [
          {
            "node": "Response - Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  }
}